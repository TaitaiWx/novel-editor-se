{
  "name": "@novel-editor/pc",
  "version": "1.1.0-beta.16",
  "private": true,
  "description": "Novel Editor - Electron desktop application",
  "author": "Novel Editor Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/TaitaiWx/novel-editor-se.git",
    "directory": "apps/pc"
  },
  "main": "./dist/main.mjs",
  "scripts": {
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dev": "cross-env NODE_ENV=development concurrently --kill-others --success first \"pnpm build:main && pnpm build:preload && pnpm build:renderer --watch\" \"wait-on dist/main.mjs && nodemon --watch src/main --ext ts,mjs --exec electron .\"",
    "build:main": "cross-env VITE_ELECTRON_MAIN=true vite build",
    "build:preload": "cross-env VITE_PRELOAD=true vite build",
    "build:renderer": "vite build",
    "build": "rimraf dist && pnpm build:main && pnpm build:preload && pnpm build:renderer",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "start": "electron .",
    "build:prod": "cross-env NODE_ENV=production pnpm build",
    "package": "pnpm build:prod && electron-builder",
    "clean": "rimraf dist build out",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/merge": "^6.12.1",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@novel-editor/basic-algorithm": "workspace:*",
    "@novel-editor/helpers": "workspace:*",
    "@novel-editor/store": "workspace:*",
    "better-sqlite3": "^12.8.0",
    "directory-tree": "^3.5.2",
    "docx": "^9.6.1",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "fs-extra": "^11.3.0",
    "mammoth": "^1.12.0",
    "marked": "^17.0.4",
    "exceljs": "^4.4.0",
    "jszip": "^3.10.1",
    "pdfjs-dist": "^5.5.207",
    "pptxgenjs": "^4.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.0",
    "@electron/rebuild": "^4.0.3",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.0.10",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@types/react-icons": "^3.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^41.0.3",
    "electron-builder": "^24.13.3",
    "electron-builder-squirrel-windows": "24.13.3",
    "nodemon": "^3.1.0",
    "rimraf": "^6.0.1",
    "sass": "^1.72.0",
    "vite": "^6.2.0",
    "wait-on": "^7.2.0"
  }
}
